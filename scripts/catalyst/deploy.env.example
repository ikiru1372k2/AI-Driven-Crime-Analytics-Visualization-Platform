# FORECAST predictor secrets for scripts/catalyst/deploy_backend.sh — TEMPLATE.
#
# Copy this file to deploy.env (same directory) and fill in the real values.
# deploy.env is git-ignored and must NEVER be committed (ADR-001). The deploy
# script auto-sources it and refuses to deploy if any predictor secret below is
# empty (so a deploy can't silently ship an "unavailable" forecast again).
#
#   cp scripts/catalyst/deploy.env.example scripts/catalyst/deploy.env
#   # edit deploy.env, then:
#   bash scripts/catalyst/deploy_backend.sh
#
# Values come from the Zoho Catalyst console (QuickML endpoint + self-client
# OAuth). See docs/catalyst/quickml-forecast-SETUP.md for how to obtain each.

# --- required: live QuickML regression predictor (OAuth REST path) ------------
KAVACH_QUICKML_RISK_ENDPOINT=""   # endpoint key (X-QUICKML-ENDPOINT-KEY)
KAVACH_QUICKML_RISK_URL=""        # full predict URL: .../endpoints/<id>/predict
KAVACH_ZOHO_CLIENT_ID=""          # self-client id
KAVACH_ZOHO_CLIENT_SECRET=""      # self-client secret
KAVACH_ZOHO_REFRESH_TOKEN=""      # refresh token, scope QuickML.deployment.READ
KAVACH_QUICKML_ORG_ID="60078928452"

# --- optional: environment + accounts host (sane defaults if omitted) ---------
KAVACH_QUICKML_ENVIRONMENT="Development"
KAVACH_ZOHO_ACCOUNTS_URL="https://accounts.zoho.in"

# --- optional: GLM plain-English summaries (falls back to templates if unset) --
KAVACH_QUICKML_LLM_ENDPOINT=""    # .../glm/chat
KAVACH_QUICKML_LLM_MODEL_ID=""    # e.g. crm-di-glm47b_30b_it
KAVACH_QUICKML_LLM_MODEL="GLM-4.7"  # friendly provenance label shown to users

# --- optional: live Catalyst Data Store source (CAT-002 / PR-B) ---------------
# Leave KAVACH_DATA_SOURCE unset/"csv" to serve bundled CSVs (prod-safe default).
# Set "datastore" to read rows live from the Catalyst Data Store via OAuth REST,
# so console edits show up in the app within KAVACH_DATASTORE_TTL seconds.
# CATALYST_PROJECT_ID is already required to deploy (exported or set here); the
# datastore adapter reuses it plus KAVACH_ZOHO_CLIENT_ID/SECRET/ACCOUNTS_URL. The
# deploy maps it to the runtime as KAVACH_CATALYST_PROJECT_ID because the AppSail
# runtime reserves the CATALYST_* prefix (a CATALYST_* key in env_variables is
# rejected with HTTP 400). The refresh token is a SEPARATE token scoped
# ZohoCatalyst.zcql.CREATE (see docs/catalyst/datastore-read-adapter.md). Never
# commit deploy.env (ADR-001).
KAVACH_DATA_SOURCE="csv"                 # "csv" (default) or "datastore"
CATALYST_PROJECT_ID=""                   # Catalyst project id (mapped to KAVACH_CATALYST_PROJECT_ID at deploy)
KAVACH_DATASTORE_REFRESH_TOKEN=""        # refresh token, scope ZohoCatalyst.zcql.CREATE
KAVACH_DATASTORE_API_BASE="https://api.catalyst.zoho.in"  # Catalyst DC base
KAVACH_DATASTORE_TTL="300"               # per-table cache seconds; 0 disables
